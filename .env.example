GREEN_API_ID_INSTANCE=1101000001
GREEN_API_TOKEN_INSTANCE=your_green_api_token
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.2
MAX_HISTORY_MESSAGES=8
IGNORE_GROUP_CHATS=true
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/your_deployment_id/exec
CATALOG_REFRESH_SECONDS=60
PAYMENT_KASPI_QR_FILE=assets/payment/kaspi_qr.jpg
GOOGLE_APPS_SCRIPT_SECRET=change_me_shared_secret
CLIENTS_SHEET_NAME=Clients
BOT_SYSTEM_PROMPT=You are a warm WhatsApp sales specialist for a furniture/beauty-zone product shop. Speak naturally like a real consultant, answer the customer's exact question first, add one useful benefit, and guide the customer to one clear next step. Use only the provided catalog data for product facts such as price, stock, color, delivery, size, and description. If data is missing, say that clearly and ask one short clarifying question. Never invent prices, delivery dates, scarcity, or guarantees.
